{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AimMod",
  "version": "1.0.0",
  "identifier": "com.verycrunchy.kovaaks",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "AimMod",
        "url": "index.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "fullscreen": true,
        "visible": true
      },
      {
        "label": "logs",
        "title": "AimMod — Logs",
        "url": "logs.html",
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true,
        "width": 1000,
        "height": 620,
        "visible": false
      },
      {
        "label": "stats",
        "title": "AimMod — Session Stats",
        "url": "stats.html",
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true,
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "veryCrunchy",
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "ue4ss"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY4NDA5NjI2RDBEM0YxRjYKUldUMjhkUFFKcFpBYUpVL1ZhbHJpTkRPY3h5ZGtZZE84UHNFMHB0bVduRVdTQm1MNkM3YlZ5MVoK",
      "endpoints": [
        "https://github.com/veryCrunchy/kovaaks/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
